{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "~/*": ["./app/*"],
      "@/*": ["./app/*"],
      "#types/*": ["./app/types/*"],
      "#utils/*": ["./app/utils/*"],
      "#constants/*": ["./app/constants/*"],
      "#imports": ["./.nuxt/imports.d.ts"]
    },
    "moduleResolution": "bundler",
    "types": ["node", "vite/client", "nuxt"]
  },
  "exclude": ["dist", ".output", "node_modules"]
}
